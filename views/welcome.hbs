{{> menu}}

<section class="ui very padded segment page-hero">
  <div class="project-badge">Student CA2 Submission</div>
  <div class="ui stackable grid middle aligned">
    <div class="eight wide column">
      <h1 class="ui header">{{info.appName}}</h1>
      <h3 class="ui header sub text-muted">{{info.tagline}}</h3>
      <p>{{info.welcomeText}}</p>
      <a class="ui orange button" href="/dashboard">Open Dashboard</a>
    </div>
    <div class="eight wide column">
      <img class="ui large bordered rounded image" src="{{info.heroImage}}" alt="{{info.heroImageAlt}}">
    </div>
  </div>
</section>

<section class="ui segment">
  <h3 class="ui header">Live App Statistics</h3>
  <div class="ui small statistics">
    <div class="statistic">
      <div class="value">{{appStats.users}}</div>
      <div class="label">Users</div>
    </div>
    <div class="statistic">
      <div class="value">{{appStats.categories}}</div>
      <div class="label">Collections</div>
    </div>
    <div class="statistic">
      <div class="value">{{appStats.activities}}</div>
      <div class="label">Volcanoes</div>
    </div>
    <div class="statistic">
      <div class="value">{{appStats.averageHeight}}</div>
      <div class="label">Avg Height</div>
    </div>
  </div>
</section>

<section class="ui two column stackable grid">
  <div class="column">
    <div class="ui segment">
      <h3 class="ui header">What this project does</h3>
      <p>
        I used the ActivityCollection structure from class and adapted it to volcano data. Categories are shown on one
        page, and full item details are shown on a separate page.
      </p>
    </div>
  </div>
  <div class="column">
    <div class="ui segment">
      <h3 class="ui header">Quick guide</h3>
      <ul class="ui list">
        <li>Go to Dashboard to view categories.</li>
        <li>Click the eye icon to open category details.</li>
        <li>Check About for contact, map, and stats.</li>
      </ul>
    </div>
  </div>
</section>
