{{> menu}}

<section class="ui very padded segment page-hero">
  <div class="project-badge">Student CA1 Submission</div>
  <div class="ui stackable grid middle aligned">
    <div class="eight wide column">
      <h1 class="ui header">{{info.appName}}</h1>
      <h3 class="ui header sub text-muted">{{info.tagline}}</h3>
      <p>{{info.welcomeText}}</p>
      <a class="ui orange button" href="/dashboard">Explore Categories</a>
    </div>
    <div class="eight wide column">
      <img class="ui large bordered rounded image" src="{{info.heroImage}}" alt="{{info.heroImageAlt}}">
    </div>
  </div>
</section>

<section class="ui two column stackable grid">
  <div class="column">
    <div class="ui segment">
      <h3 class="ui header">Project idea</h3>
      <p>
        This web app uses an ActivityCollection-style structure and customizes it for volcano data. The goal is to
        show clean MVC separation and render category/item data from JSON stores.
      </p>
    </div>
  </div>
  <div class="column">
    <div class="ui segment">
      <h3 class="ui header">How to use it</h3>
      <ul class="ui list">
        <li>Open Dashboard to see all volcano categories.</li>
        <li>Use the icon link to open full item details.</li>
        <li>Open About to view contact info, map, and stats.</li>
      </ul>
    </div>
  </div>
</section>
