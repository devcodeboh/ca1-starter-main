{{> menu}}

<section class="ui segment auth-panel">
  <h2 class="ui header">Login</h2>
  <p>Use your account to open and manage your own collections.</p>

  {{#if error}}
    <div class="ui negative message">{{error}}</div>
  {{/if}}

  <form class="ui form" action="/login" method="POST">
    <div class="field">
      <label>Email</label>
      <input type="email" name="email" value="{{form.email}}" required>
    </div>
    <div class="field">
      <label>Password</label>
      <input type="password" name="password" required>
    </div>
    <button class="ui button" type="submit">Login</button>
    <a class="ui basic button" href="/signup">Signup</a>
  </form>

  <div class="ui small message demo-login">
    Demo account: bohdan@example.com / Password1!
  </div>
</section>
