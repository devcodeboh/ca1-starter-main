{{> menu}}

{{#if category}}
<section class="ui segment">
  <h2 class="ui header">{{category.title}}</h2>
  <p>Detailed item properties for this category.</p>

  <form class="ui form filter-form" action="/dashboard/{{category.id}}" method="GET">
    <div class="four fields">
      <div class="field">
        <label>Search</label>
        <input type="text" name="search" value="{{search}}" placeholder="Name, country, risk, monitoring">
      </div>
      <div class="field">
        <label>Sort By</label>
        <select name="sortBy">
          <option value="{{sortBy}}" selected>{{sortBy}}</option>
          <option value="name">name</option>
          <option value="country">country</option>
          <option value="riskLevel">riskLevel</option>
          <option value="heightM">heightM</option>
          <option value="monitoringStatus">monitoringStatus</option>
        </select>
      </div>
      <div class="field">
        <label>Direction</label>
        <select name="direction">
          <option value="{{direction}}" selected>{{direction}}</option>
          <option value="asc">asc</option>
          <option value="desc">desc</option>
        </select>
      </div>
      <div class="field action-field">
        <button class="ui button" type="submit">Apply</button>
      </div>
    </div>
  </form>

  <form class="ui form add-form" action="/dashboard/{{category.id}}/addactivity" method="POST" enctype="multipart/form-data">
    <h3 class="ui header">Add Volcano</h3>
    <div class="three fields">
      <div class="field">
        <label>Name</label>
        <input type="text" name="name" required>
      </div>
      <div class="field">
        <label>Country</label>
        <input type="text" name="country" required>
      </div>
      <div class="field">
        <label>Last Eruption</label>
        <input type="text" name="lastEruption" placeholder="2026-01" required>
      </div>
    </div>
    <div class="four fields">
      <div class="field">
        <label>Risk Level</label>
        <select name="riskLevel" required>
          <option value="Low">Low</option>
          <option value="Medium">Medium</option>
          <option value="High">High</option>
        </select>
      </div>
      <div class="field">
        <label>Height (m)</label>
        <input type="number" name="heightM" min="0" required>
      </div>
      <div class="field">
        <label>Monitoring</label>
        <input type="text" name="monitoringStatus" required>
      </div>
      <div class="field">
        <label>Image</label>
        <input type="file" name="image" accept="image/*">
      </div>
    </div>
    <button class="ui button" type="submit">Add Item</button>
  </form>

  <div class="ui three stackable cards">
    {{#each category.activities}}
      <div class="card">
        <div class="image">
          <img src="{{image}}" alt="{{imageAlt}}">
        </div>
        <div class="content">
          <div class="header">{{name}}</div>
          <div class="meta">{{country}}</div>
          <div class="description details-list">
            <p><strong>Last Eruption:</strong> {{lastEruption}}</p>
            <p><strong>Risk Level:</strong> {{riskLevel}}</p>
            <p><strong>Height (m):</strong> {{heightM}}</p>
            <p><strong>Monitoring:</strong> {{monitoringStatus}}</p>
          </div>
        </div>
        <div class="extra content">
          <a class="ui icon button" href="/dashboard/{{../category.id}}/editactivity/{{id}}" title="Edit {{name}}">
            <i class="edit icon"></i>
          </a>
          <form class="inline-form" action="/dashboard/{{../category.id}}/deleteactivity/{{id}}" method="POST">
            <button class="ui icon negative button confirm-delete" type="submit" title="Delete {{name}}">
              <i class="trash icon"></i>
            </button>
          </form>
        </div>
      </div>
    {{else}}
      <div class="ui message">No volcanoes in this collection yet.</div>
    {{/each}}
  </div>

  <a class="ui basic button" href="/dashboard">Back to Dashboard</a>
</section>
{{else}}
<section class="ui negative segment">
  <h3 class="ui header">Category not found</h3>
  <p>The requested category does not exist.</p>
  <a class="ui button" href="/dashboard">Return to Dashboard</a>
</section>
{{/if}}
