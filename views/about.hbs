{{> menu}}

<section class="ui stackable grid">
  <div class="sixteen wide column">
    <div class="ui segment">
      <h2 class="ui header">Contact</h2>
      <p><strong>Name:</strong> {{author.name}}</p>
      <p><strong>Role:</strong> {{author.role}}</p>
      <p><strong>Email:</strong> {{author.email}}</p>
      <p><strong>Phone:</strong> {{author.phone}}</p>
      <p><strong>Location:</strong> {{author.location}}</p>
      <div class="student-note">
        CA1 project page. Data on this page is loaded from JSON files.
      </div>
    </div>

    <div class="ui segment">
      <h3 class="ui header">App Statistics</h3>
      <div class="ui small statistics">
        <div class="statistic">
          <div class="value">{{collectionStats.categories}}</div>
          <div class="label">Categories</div>
        </div>
        <div class="statistic">
          <div class="value">{{collectionStats.activities}}</div>
          <div class="label">Items</div>
        </div>
        <div class="statistic">
          <div class="value">{{collectionStats.monitoredContinuously}}</div>
          <div class="label">Continuous Monitoring</div>
        </div>
        <div class="statistic">
          <div class="value">{{userCount}}</div>
          <div class="label">Users</div>
        </div>
        <div class="statistic">
          <div class="value">{{collectionStats.averageItemsPerCategory}}</div>
          <div class="label">Avg Items</div>
        </div>
        <div class="statistic">
          <div class="value">{{collectionStats.maxHeight}}</div>
          <div class="label">Max Height</div>
        </div>
      </div>

      <div class="ui message">
        Top collector: <strong>{{topCollector.name}}</strong> with {{topCollector.collections}} collections.
      </div>

      {{#if currentUserStats}}
        <h4 class="ui header">Your Statistics</h4>
        <div class="ui list">
          <div class="item"><strong>Your collections:</strong> {{currentUserStats.categories}}</div>
          <div class="item"><strong>Your volcanoes:</strong> {{currentUserStats.activities}}</div>
          <div class="item"><strong>Your average height:</strong> {{currentUserStats.averageHeight}} m</div>
        </div>
      {{/if}}

      <div class="ui list">
        {{#each staticStats}}
          <div class="item">
            <i class="info circle icon"></i>
            <div class="content"><strong>{{label}}:</strong> {{value}}</div>
          </div>
        {{/each}}
      </div>
    </div>

    <div class="ui segment">
      <h3 class="ui header">Project Notes</h3>
      <div class="ui relaxed divided list">
        {{#each projectNotes}}
          <div class="item">
            <i class="bookmark icon"></i>
            <div class="content">
              <div class="header">{{title}}</div>
              <div class="description">{{text}}</div>
            </div>
          </div>
        {{/each}}
      </div>
    </div>

    <div class="ui segment">
      <h3 class="ui header">{{map.title}}</h3>
      <iframe
        class="map-embed"
        src="{{map.embedUrl}}"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Google Map for Ballybricken 36"></iframe>
    </div>
  </div>
</section>
